#!/bin/sh
set -e

if ! getent passwd systemprompt >/dev/null; then
  adduser --system --group --no-create-home --home /var/lib/systemprompt systemprompt
fi

install -d -o systemprompt -g systemprompt -m 0755 /var/lib/systemprompt /var/log/systemprompt

if [ ! -f /etc/systemprompt/systemprompt.env ]; then
  cat > /etc/systemprompt/systemprompt.env <<'EOF'
# systemprompt environment
# DATABASE_URL=postgres://systemprompt:pw@localhost:5432/systemprompt
# ANTHROPIC_API_KEY=
# HOST=0.0.0.0
# PORT=8080
EOF
  chmod 0640 /etc/systemprompt/systemprompt.env
  chown root:systemprompt /etc/systemprompt/systemprompt.env
fi

#DEBHELPER#

exit 0
